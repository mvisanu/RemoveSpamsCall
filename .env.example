# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it.

# --- Search API Keys ---
SERP_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- App Settings ---
# Path to SQLite database (default: ~/.privacytool/tracker.db)
# PRIVACYTOOL_DB_PATH=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to 1 to store master key in OS keychain after first unlock
USE_KEYCHAIN=0
